# KICKOFF local backend
PORT=3001
HOST=127.0.0.1
TEAM_NATION=Ghana

# QVAC — local inference (no API key)
# Registry model constant from @qvac/sdk exports
QVAC_MODEL=LLAMA_3_2_1B_INST_Q4_0
# QVAC_MODEL_PATH=/path/to/model.gguf
# QVAC_HTTP_URL=http://127.0.0.1:8080   # optional local inference HTTP server

# WDK — Sepolia testnet
WDK_NETWORK=sepolia
WDK_EVM_PROVIDER=https://ethereum-sepolia-rpc.publicnode.com
# Official Sepolia USD₮ per WDK docs — https://docs.wdk.tether.io/start-building/react-native-quickstart
WDK_USDT_TOKEN_ADDRESS=0xaA8E23Fb1079EA71e0a56F48a2aA51851D8433D0

# CORS for local frontend dev
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend → API (Vite)
# VITE_API_BASE=http://127.0.0.1:3001

# TinyFish — live match data (server-side only, NOT for AI)
# Get key: https://agent.tinyfish.ai/api-keys
# TINYFISH_API_KEY=
# TINYFISH_USE_AGENT=1
# TINYFISH_LIVE_URL=https://www.fifa.com/en/tournaments/mens/worldcup/canadamexicousa2026
# LIVE_DATA_CACHE_MS=60000
