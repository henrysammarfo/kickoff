# KICKOFF local backend
PORT=3001
HOST=127.0.0.1
TEAM_NATION=Ghana

# QVAC — local inference (no API key)
# Registry model constant from @qvac/sdk exports
QVAC_MODEL=LLAMA_3_2_1B_INST_Q4_0
# QVAC_MODEL_PATH=/path/to/model.gguf
# QVAC_HTTP_URL=http://127.0.0.1:8080   # linestackruntime OpenAI-compatible server
# QVAC_LINESTACK_RUNTIME_PATH=/path/to/linestackruntime

# WDK — Sepolia testnet
WDK_NETWORK=sepolia
WDK_EVM_PROVIDER=https://ethereum-sepolia-rpc.publicnode.com
# WDK_USDT_TOKEN_ADDRESS=0x...

# CORS for Lovable dev server
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
